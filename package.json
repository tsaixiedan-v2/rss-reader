{
  "name": "rss-reader",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/main/typescript/api/server.ts",
    "dev:client": "cd client && npm run dev",
    "build": "tsc && cd client && npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "concurrently": "^8.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
